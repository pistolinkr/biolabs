{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/uniprot/:path*",
      "destination": "https://rest.uniprot.org/:path*"
    },
    {
      "source": "/api/rcsb-search/:path*",
      "destination": "https://search.rcsb.org/:path*"
    },
    {
      "source": "/api/rcsb-files/:path*",
      "destination": "https://files.rcsb.org/:path*"
    },
    {
      "source": "/api/alphafold/:path*",
      "destination": "https://alphafold.ebi.ac.uk/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
