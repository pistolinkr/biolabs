# =============================================================================
# Biolabs AI Assistant — server-side only (never expose to VITE_* client vars)
# =============================================================================

# Provider selection: auto, gemini, openrouter, or huggingface
AI_PROVIDER=auto

# --- Gemini (recommended free tier via Google AI Studio) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenRouter (free models available) ---
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# --- Hugging Face Inference API ---
# Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# --- Output limits ---
AI_MAX_CONTEXT_CHARS=24000
AI_MAX_OUTPUT_TOKENS=1024

# --- Helix / FDA OpenFDA (server proxy only — never expose to VITE_*) ---
# Get key: https://open.fda.gov/apis/authentication/
FDA_API_KEY=

# Server port (production)
PORT=3000
