# =============================================================================
# Biolabs AI Assistant — server-side only (never expose to VITE_* client vars)
# =============================================================================

# Provider selection: auto, gemini, openrouter, or huggingface
AI_PROVIDER=auto

# --- Gemini (recommended free tier via Google AI Studio) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenRouter (free models available) ---
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# --- Hugging Face Inference API ---
# Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# --- Limits ---
AI_MAX_CONTEXT_CHARS=24000
AI_MAX_OUTPUT_TOKENS=1024
# HTTP rate limit (requests/min/IP) for /api/ai/chat
AI_RATE_LIMIT_PER_MIN=20

# --- Per-provider budget (in-memory, resets on restart) ---
AI_PROVIDER_RPM=15
AI_PROVIDER_DAILY=1000

# --- Global intent-weighted call policy (across all providers) ---
# Weighted units per rolling minute / per day, and max concurrent upstream calls.
AI_GLOBAL_RPM=30
AI_GLOBAL_DAILY=500
AI_MAX_CONCURRENT=2
# Strict mode (1/true): never bypass throttled providers as a last resort.
AI_STRICT_LIMITS=1
# Optional per-intent weights (default: structure/agent=2, residue/analysis=1, test=0.5)
AI_INTENT_WEIGHT_STRUCTURE=2
AI_INTENT_WEIGHT_AGENT=2

# Server port (production)
PORT=3000
